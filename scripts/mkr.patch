+class Expand(nn.Module):
+    def __init__(self, in_c: int, out_c: int, stride: int = 1):
+        super().__init__()
+        self.conv1 = nn.Conv2d(
+            in_channels=in_c,
+            out_channels=out_c // 2,
+            kernel_size=1,
+            bias=False,
+            stride=stride,
+        )
+        self.conv3 = nn.Conv2d(
+            in_channels=in_c,
+            out_channels=out_c // 2,
+            kernel_size=3,
+            bias=False,
+            stride=stride,
+        )
+        self.relu = nn.SquarePN()
+
+    def forward(self, x: ModuleV) -> ModuleV:
+        y1 = self.conv1(x)
+        y2 = self.conv3(x)
+
+        y = lib.concat(y1, y2, dim=-3)
+        y = self.relu(y)
+
+        return y
+
+
+class ExpandAvgPool(nn.Module):
+    def __init__(self, in_c: int, out_c: int, stride: int = 1):
+        super().__init__()
+        self.conv1 = nn.Conv2d(
+            in_channels=in_c,
+            out_channels=out_c // 2,
+            kernel_size=1,
+            bias=False,
+            stride=stride,
+        )
+        self.conv3 = nn.Conv2d(
+            in_channels=in_c,
+            out_channels=out_c // 2,
+            kernel_size=3,
+            bias=False,
+            stride=stride,
+        )
+        self.avgpool = nn.AvgPool2d(kernel_size=2, stride=2)
+        self.relu = nn.SquarePN()
+
+    def forward(self, x: ModuleV) -> ModuleV:
+        y1 = self.conv1(x)
+        y1 = self.avgpool(y1)
+        y2 = self.conv3(x)
+        y2 = self.avgpool(y2)
+
+        y = lib.concat(y1, y2, dim=-3)
+        y = self.relu(y)
+
+        return y;
