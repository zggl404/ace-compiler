+import argparse
+from pathlib import Path
+
+def format_timing_file(input_path):
+    """Format timing file with aligned columns"""
+    # Validate input file
+    if not input_path.exists():
+        print(f"Error: Input file {input_path} not found")
+        return False
+
+    # Generate output filename
+    output_path = input_path.with_stem(f"{input_path.stem}_formatted")
+
+    # Column configuration
+    columns = [
+        ("OP", 10, '<'),    
+        ("LEVEL", 7, '>'), 
+        ("COUNT", 7, '>'),  
+        ("EXEC", 9, '>'),   
+        ("LOAD(MB)", 9, '>'),
+        ("DRAM(MB)", 9, '>')
+    ]
+    
+    # Create format strings
+    header_fmt = "|".join([f" {{:{align}{width}}} " for _, width, align in columns])
+    separator = "|".join(["-" * (width + 2) for _, width, _ in columns])
+    
+    data = []
+
+    try:
+        with open(input_path, 'r') as f:
+            for line in f:
+                line = line.strip()
+                if '@' not in line:
+                    continue
+                
+                parts = line.split()
+                if len(parts) < 4:
+                    continue
+                
+                # Parse OP and LEVEL
+                op_part = parts[0].rstrip(':')
+                op, level = op_part.split('@')
+                
+                # Extract values
+                try:
+                    exec_val = int(parts[2])
+                except (ValueError, IndexError):
+                    continue
+                
+                data.append({
+                    'op': op,
+                    'level': int(level),
+                    'exec': exec_val
+                })
+
+        # Build output
+        output = []
+        output.append("|" + header_fmt.format(*[col[0] for col in columns]) + "|")
+        output.append("|" + separator + "|")
+        
+        for entry in data:
+            output.append("|" + header_fmt.format(
+                entry['op'],
+                entry['level'],
+                0,
+                entry['exec'],
+                0.0,
+                0.0
+            ) + "|")
+
+        # Write to file
+        with open(output_path, 'w') as f:
+            f.write('\n'.join(output))
+        
+        print(f"Successfully created formatted file: {output_path}")
+        return True
+
+    except Exception as e:
+        print(f"Processing error: {str(e)}")
+        return False
+
+def main():
+    # Configure command line arguments
+    parser = argparse.ArgumentParser(
+        description='Timing File Formatter',
+        formatter_class=argparse.ArgumentDefaultsHelpFormatter
+    )
+    parser.add_argument(
+        '-i', '--input',
+        type=Path,
+        required=True,
+        help='Input file path to process'
+    )
+    
+    args = parser.parse_args()
+    
+    # Process file
+    success = format_timing_file(args.input)
+    
+    # Exit code based on result
+    exit(0 if success else 1)
+
+if __name__ == "__main__":
+    main()
