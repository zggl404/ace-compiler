+class Squeeze(nn.Module):
+    def __init__(self, in_c: int, out_c: int):
+        super().__init__()
+        self.conv = nn.Conv2d(
+            in_channels=in_c, out_channels=out_c, kernel_size=1, bias=False
+        )
+        self.relu = nn.SquarePN()
+
+    def forward(self, x: ModuleV) -> ModuleV:
+        x = self.conv(x)
+        x = self.relu(x)
+        return x
