+
+namespace fhelipe {
+class CtOp;
+
+TTimestampC::TTimestampC(const TensorLayout& layout, int kind, int idx)
+    : layout_(layout), kind_(kind), idx_(idx) {}
+
+TOp::LaidOutTensorCt TTimestampC::AmendCtProgram(
+    ct_program::CtProgram& ct_program,
+    const std::vector<LaidOutTensorCt>& input_tensors) const {
+  CHECK(input_tensors.size() == 1);
+  CHECK(input_tensors[0].Layout() == layout_);
+
+  auto result =
+      Estd::transform(input_tensors[0].Chunks(), [&](const auto& chunk) {
+        return TOp::LaidOutChunk(
+            chunk.Layout(), chunk.Offset(),
+            ct_program::CreateTimestampC(
+                ct_program, kind_, idx_,
+                chunk.Chunk()));
+      });
+  return TOp::LaidOutTensorCt{result};
+}
+
+void TTimestampC::SetLayouts(const TensorLayout& input_layout,
+                             const TensorLayout& output_layout) {
+  CHECK(input_layout == output_layout);
+  layout_ = input_layout;
+}
+
+bool TTimestampC::EqualTo(const TOp& other) const {
+  const auto* t_timestamp_c = dynamic_cast<const TTimestampC*>(&other);
+  return t_timestamp_c && t_timestamp_c->OutputLayout() == OutputLayout() &&
+	  t_timestamp_c->Kind() == kind_ && t_timestamp_c->Idx() == idx_;
+}
+
+}  // namespace fhelipe
