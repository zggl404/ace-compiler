+#ifndef FHELIPE_T_TIMESTAMP_C_H_
+#define FHELIPE_T_TIMESTAMP_C_H_
+
+#include <memory>
+
+#include "include/constants.h"
+#include "log_scale.h"
+#include "t_op.h"
+
+namespace fhelipe {
+
+class TTimestampC;
+
+template <>
+void WriteStream<TTimestampC>(std::ostream& stream, const TTimestampC& node);
+
+class TTimestampC final : public TOp {
+ public:
+  TTimestampC(const TensorLayout& layout, int kind, int idx);
+  LaidOutTensorCt AmendCtProgram(
+      ct_program::CtProgram& ct_program,
+      const std::vector<LaidOutTensorCt>& input_tensors) const final;
+
+  std::unique_ptr<TOp> CloneUniq() const final {
+    return std::make_unique<TTimestampC>(*this);
+  }
+
+  const TensorLayout& OutputLayout() const final { return layout_; }
+  int Kind() const { return kind_; }
+  int Idx() const { return idx_; }
+
+  const std::string& TypeName() const final { return StaticTypeName(); }
+
+  void WriteStreamHelper(std::ostream& stream) const final {
+    WriteStream<TTimestampC>(stream, *this);
+  }
+  void SetLayouts(const TensorLayout& input_layout,
+                  const TensorLayout& output_layout) final;
+
+  static const std::string& StaticTypeName() {
+    static const std::string type_name_ = "TTimestampC";
+    return type_name_;
+  }
+
+ private:
+  TensorLayout layout_;
+  int kind_;
+  int idx_;
+
+  static TOpDerivedRegistrar<TTimestampC> reg_;
+  bool EqualTo(const TOp& other) const final;
+};
+
+inline TOpDerivedRegistrar<TTimestampC> TTimestampC::reg_{
+    TTimestampC::StaticTypeName()};
+
+template <>
+inline void WriteStream<TTimestampC>(std::ostream& stream,
+                                   const TTimestampC& node) {
+  WriteStream<std::string>(stream, TTimestampC::StaticTypeName());
+  stream << " ";
+  WriteStream<TensorLayout>(stream, node.OutputLayout());
+  stream << " ";
+  WriteStream<int>(stream, node.Kind());
+  stream << " ";
+  WriteStream<int>(stream, node.Idx());
+}
+
+template <>
+inline TTimestampC ReadStreamWithoutTypeNamePrefix<TTimestampC>(
+    std::istream& stream) {
+  auto tensor_layout = ReadStream<TensorLayout>(stream);
+  auto kind = ReadStream<int>(stream);
+  auto idx = ReadStream<int>(stream);
+  return {tensor_layout, kind, idx};
+}
+
+}  // namespace fhelipe
+
+#endif  // FHELIPE_T_TIMESTAMP_C_H_
