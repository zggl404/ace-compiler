+import logging
+from argparse import ArgumentParser
+from math import pi, sqrt
+from pathlib import Path
+from typing import Final, Mapping
+
+import tensorfhe as tfhe
+import tensorfhe.app.actions as act
+import torch
+from tensorfhe import TorchInput, TensorV, lib, nn
+from tensorfhe.nn import ModuleV
+from torch.optim import Optimizer
+from torch.optim.lr_scheduler import CosineAnnealingLR, LambdaLR, LinearLR
+from torchvision.transforms import RandomCrop, RandomHorizontalFlip
+
+
+class AlexNet(nn.Sequential):
+    def __init__(self, num_classes: int):
+        super().__init__(
+            nn.Conv2d(
+                in_channels=3, out_channels=64, kernel_size=3, bias=False, stride=1
+            ),
+            nn.ApproxRelu(alpha=13),
+            nn.AvgPool2d(kernel_size=2, stride=2),
+            nn.Conv2d(
+                in_channels=64, out_channels=192, kernel_size=3, bias=False, stride=1
+            ),
+            nn.ApproxRelu(alpha=13),
+            nn.AvgPool2d(kernel_size=2, stride=2),
+            nn.Conv2d(
+                in_channels=192, out_channels=384, kernel_size=3, bias=False, stride=1
+            ),
+            nn.ApproxRelu(alpha=13),
+            nn.Conv2d(
+                in_channels=384, out_channels=256, kernel_size=3, bias=False, stride=1
+            ),
+            nn.ApproxRelu(alpha=13),
+            nn.Conv2d(
+                in_channels=256, out_channels=256, kernel_size=3, bias=False, stride=1
+            ),
+            nn.ApproxRelu(alpha=13),
+            #nn.AvgPool2d(kernel_size=2, stride=2),
+            nn.GlobalAvgPool2d(),
+            nn.Linear(256, 4096),
+            nn.ApproxRelu(alpha=13),
+            nn.Linear(4096, 4096),
+            nn.ApproxRelu(alpha=13),
+            nn.Linear(4096, num_classes)
+        )
+
+
+class AlexNetPreprocess(torch.nn.Module):
+    def __init__(self):
+        super().__init__()
+        self.module = torch.nn.Sequential(
+            RandomHorizontalFlip(), RandomCrop((32, 32), padding=4)
+        )
+
+    def forward(self, x: torch.Tensor) -> torch.Tensor:
+        if self.training:
+            return self.module(x)
+        else:
+            return x
+
+
+class AlexNetError(act.ArgMaxOutputMixin, act.Cifar10TestError):
+    pass
+
+
+class AlexNetWeights(act.PopulateSharedCheckpoint):
+    def __weight_tensors(
+        self
+    ) -> Mapping[str, torch.Tensor]:
+        tensors = {}
+        scale = 100.
+        bias = 0.
+        tensors['nn.17.bias'] = torch.randn (10) / scale - bias
+        tensors['nn.17.weight'] = torch.randn(10, 4096) / scale - bias
+        tensors['nn.16.max'] = 10.
+        tensors['nn.15.bias']= torch.randn (4096)  / scale - bias
+        tensors['nn.15.weight'] = torch.randn(4096, 4096) / scale - bias
+        tensors['nn.14.max'] = 10.
+        tensors['nn.13.bias'] = torch.randn(4096) / scale - bias
+        tensors['nn.13.weight'] = torch.randn(4096, 256) / scale - bias
+        tensors['nn.11.max'] = 10.
+        tensors['nn.10.weight'] = torch.randn(256, 256, 3, 3) / scale - bias
+        tensors['nn.9.max'] = 10.
+        tensors['nn.8.weight'] = torch.randn(256, 384, 3, 3) / scale - bias
+        tensors['nn.7.max'] = 10.
+        tensors['nn.6.weight'] = torch.randn(384, 192, 3, 3) / scale - bias
+        tensors['nn.4.max'] = 10.
+        tensors['nn.3.weight'] = torch.randn(192, 64, 3, 3) / scale - bias
+        tensors['nn.1.max'] = 10.
+        tensors['nn.0.weight'] = torch.randn(64, 3, 3, 3) / scale - bias
+
+        return tensors
+
+    def shared_in(self, exe: tfhe.app.ExeManager) -> Mapping[str, TensorV]:
+        return self.__weight_tensors()
+
+
+class AlexNetApp(tfhe.NnApp):
+    actions = {
+        *act.common_nn_actions,
+        act.Cifar10TestIn,
+        AlexNetError,
+        AlexNetWeights,
+    }
+    input_shape = act.Cifar10TestIn.input_shape
+
+    def __init__(self, **kwargs):
+        super().__init__(
+            nn=nn.SimpleNN(
+                module=AlexNet(10),
+                preprocess=AlexNetPreprocess(),
+                input_shape=act.Cifar10TestIn.input_shape,
+            ),
+        )
+
+
+if __name__ == "__main__":
+    AlexNetApp.main()
