+ * WARRANTY; without even the implied warranty of MERCHANTABILITY or FITNESS
+ * FOR A PARTICULAR PURPOSE. See the GNU General Public License for more
+ * details.
+ *
+ * You should have received a copy of the GNU General Public License along with
+ * this program. If not, see <http://www.gnu.org/licenses/>. 
+ */
+
+#include "include/timestamp_c.h"
+
+#include <chrono>
+#include <fstream>
+#include <glog/logging.h>
+
+namespace fhelipe {
+
+class TimingInfoImpl {
+ private:
+  using timing_t = std::chrono::time_point<std::chrono::high_resolution_clock>;
+  using elapse_t = std::chrono::duration<long, std::micro>;
+  static constexpr double microsecond = 1000000.;
+  static constexpr timing_t t0_ = timing_t::min();
+  static constexpr elapse_t e0_ = elapse_t::zero();
+  static inline timing_t now() { return std::chrono::high_resolution_clock::now(); }
+  static inline elapse_t duration(timing_t e, timing_t s) { return std::chrono::duration_cast<std::chrono::microseconds>(e - s); }
+
+  struct HETimingEntry {
+    elapse_t elapse_;       // total exec time
+    uint32_t count_;        // total call count
+
+    HETimingEntry() : elapse_(e0_), count_(0) {}
+    long     Elapse() const { return elapse_.count(); }
+    double   Second() const { return (double)Elapse() / microsecond; }
+    uint32_t Count() const { return count_; }
+
+    void Reset() {
+      elapse_ = e0_;
+      count_ = 0;
+    }
+
+    void End_he(elapse_t tm) {
+      elapse_ += tm;
+      count_ ++;
+    }
+  };
+
+  struct NNTimingEntry {
+    elapse_t elapse_;       // total exec time
+    uint32_t count_;        // total call count
+    elapse_t elapse_bts_;   // bts exec time inside this NN op
+    uint32_t count_bts_;    // bts call count inside this NN op
+
+    NNTimingEntry() : elapse_(e0_), count_(0), elapse_bts_(e0_), count_bts_(0) {}
+    long     Elapse() const { return elapse_.count(); }
+    double   Second() const { return (double)Elapse() / microsecond; }
+    uint32_t Count() const { return count_; }
+    long     Elapse_bts() const { return elapse_bts_.count(); }
+    double   Second_bts() const { return (double)Elapse_bts() / microsecond; }
+    uint32_t Count_bts() const { return count_bts_; }
+
+    void End_nn(elapse_t tm, HETimingEntry bts) {
+      elapse_ += tm;
+      count_ ++;
+      elapse_bts_ += bts.elapse_;
+      count_bts_ += bts.count_;
+    }
+
+  };
+
+  std::vector< NNTimingEntry > timing_nn_;               // all NN op timing
+  std::vector< std::vector<HETimingEntry> > timing_he_;  // all HE op timing
+  HETimingEntry timing_bts_;  // BTS timing inside a NN op
+  timing_t init_;             // init timestamp
+  timing_t prev_nn_;          // previous NN op timestamp
+  timing_t prev_he_;          // previous HE op timestamp
+  int      max_level_;        // max level used to initialize timing
+  int      input_level_;      // max level of input node
+
+ public:
+   TimingInfoImpl(int max_level) {
+     timing_nn_.resize(NN_OP_MAX);
+     timing_he_.resize(HE_OP_MAX);
+     for (int i = 0; i < timing_he_.size(); ++i) {
+       timing_he_[i].resize(max_level+1);
+     }
+     init_ = now();
+     prev_nn_ = init_;
+     prev_he_ = t0_;
+     max_level_ = max_level;
+     input_level_ = 0;
+  }
+
+  void Incr(int kind, int idx) {
+    timing_t end = now();
+    timing_nn_[kind].End_nn(duration(end, prev_nn_), timing_bts_);
+    timing_bts_.Reset();
+    prev_nn_ = now();
+  }
+
+  void Begin_op(int kind, int level) {
+    assert(prev_he_ == t0_);
+    assert(level >= 1 && level <= max_level_);
+    if (kind == HE_INPUT && level > input_level_) {
+      input_level_ = level;
+    }
+    prev_he_ = now();
+  }
+
+  void End_op(int kind, int level) {
+    assert(level >= 1 && level <= max_level_);
+    elapse_t eps = duration(now(), prev_he_);
+    timing_he_[kind][level].End_he(eps);
+    if (kind == HE_BOOTSTRAP) {
+      timing_bts_.End_he(eps);
+    }
+    prev_he_ = t0_;
+  }
+
+  void Print() {
+    timing_t end = now();
+    std::ofstream ofs("ops_timing.txt");
+    long count = 0, sub_count = 0;
+    double total = 0., sub_total = 0.;
+    for (int i = 0; i < timing_nn_.size(); ++i) {
+      if (timing_nn_[i].Count() > 0) {
+        ofs << NNOpStr((NN_OP_KIND)i) << ":\t"
+	    << (timing_nn_[i].Second() - timing_nn_[i].Second_bts()) << "\t"
+            << timing_nn_[i].Second() << "\t" << timing_nn_[i].Count() << "\t"
+	    << timing_nn_[i].Second_bts() << "\t" << timing_nn_[i].Count_bts() << std::endl;
+	total += timing_nn_[i].Second();
+	count += timing_nn_[i].Count();
+	sub_total += timing_nn_[i].Second_bts();
+	sub_count += timing_nn_[i].Count_bts();
+      }
+    }
+    ofs << "total:\t" << total << "\t" << count
+	<< " bts:\t" << sub_total << "\t" << sub_count
+	<< " no_bts:\t" << (total - sub_total)
+        << std::endl << std::endl;
+    total = 0.;
+    count = 0;
+    sub_total = 0.;
+    sub_count = 0;
+    for (int i = 0; i < timing_he_.size(); ++i) {
+      for (int j = 0; j <= max_level_; ++j) {
+        if (timing_he_[i][j].Count() > 0) {
+          ofs << HEOpStr((HE_OP_KIND)i) << "@" << j << ":\t"
+              << timing_he_[i][j].Second() << "\t" << timing_he_[i][j].Count() << "\t"
+	      << (double)timing_he_[i][j].Elapse() / (double)timing_he_[i][j].Count() << std::endl;
+	  sub_total += timing_he_[i][j].Second();
+	  sub_count += timing_he_[i][j].Count();
+	}
+      }
+      if (sub_count > 0) {
+        ofs << HEOpStr((HE_OP_KIND)i) << ":\t"
+            << sub_total << "\t" << sub_count << sub_total / (double)sub_count << std::endl << std::endl;
+        total += sub_total;
+        count += sub_count;
+        sub_total = 0.;
+        sub_count = 0;
+      }
+    }
+    ofs << "total:\t" << total << "\t" << count << std::endl;
+    ofs << "total elapsed:\t" << (double)duration(end, init_).count() / microsecond << std::endl;
+    ofs.close();
+  }
+};
+
+TimingInfoImpl* TimingInfo::impl_ = nullptr;
+
+void TimingInfo::Incr(int kind, int idx) {
+  assert(impl_ != nullptr);
+  impl_->Incr(kind, idx);
+}
+
+void TimingInfo::Begin_op(int kind, int level) {
+  assert(impl_ != nullptr);
+  impl_->Begin_op(kind, level);
+}
+
+void TimingInfo::End_op(int kind, int level) {
+  assert(impl_ != nullptr);
+  impl_->End_op(kind, level);
+}
+
+void TimingInfo::Init(int max_level) {
+  assert(impl_ == nullptr);
+  impl_ = new TimingInfoImpl(max_level);
+}
+
+void TimingInfo::Fini() {
+  assert(impl_ != nullptr);
+  impl_->Print();
+  delete impl_;
+  impl_ = nullptr;
+}
+
+}  // namespace fhelipe
