+
+#ifndef FHELIPE_TIMESTAMP_C_H_
+#define FHELIPE_TIMESTAMP_C_H_
+
+#include <string>
+
+#include "ct_op.h"
+#include "ct_op_visitor.h"
+
+namespace fhelipe {
+
+class TimingInfoImpl;
+
+enum NN_OP_KIND {
+  NN_CONV            = 0,
+  NN_RELU            = 1,
+  NN_AVG_POOL        = 2,
+  NN_GLOBAL_AVG_POOL = 3,
+  NN_BATCH_NORMAL    = 4,
+  NN_HERPN           = 5,
+  NN_LINEAR          = 6,
+  NN_OP_MAX
+};
+
+enum HE_OP_KIND {
+  HE_INPUT           = 0,
+  HE_OUTPUT          = 1,
+  HE_ADDCC           = 2,
+  HE_ADDCP           = 3,
+  HE_ADDCS           = 4,
+  HE_MULCC           = 5,
+  HE_MULCP           = 6,
+  HE_MULCS           = 7,
+  HE_ROTATE          = 8,
+  HE_BOOTSTRAP       = 9,
+  HE_RESCALE         = 10,
+  HE_ZERO            = 11,
+  HE_OP_MAX
+};
+
+static inline const char* NNOpStr(NN_OP_KIND kind) {
+  static const char* names[NN_OP_MAX + 1] = {
+    "conv", "relu", "avg_pool", "global_avg_pool", "batch_normal",
+    "herpn", "linear", "-*-"
+  };
+  assert(kind >= NN_CONV && kind < NN_OP_MAX);
+  return names[kind];
+}
+
+static inline const char* HEOpStr(HE_OP_KIND kind) {
+  static const char* names[HE_OP_MAX + 1] = {
+    "input", "output", "addcc", "addcp", "addcs", "mulcc", "mulcp",
+    "mulcs", "rotate", "bootstrap", "rescale", "zero", "-*-"
+  };
+  assert(kind >= HE_INPUT && kind < HE_OP_MAX);
+  return names[kind];
+}
+
+class TimingInfo {
+ public:
+  static void Incr(int kind, int idx);
+  static void Begin_op(int kind, int level);
+  static void End_op(int kind, int level);
+  static void Init(int max_level);
+  static void Fini();
+
+ private:
+  static TimingInfoImpl* impl_;
+};
+
+class TimingHE {
+ public:
+  TimingHE(int kind, int level) : kind_(kind), level_(level) {
+    TimingInfo::Begin_op(kind_, level_);
+  }
+  ~TimingHE() { TimingInfo::End_op(kind_, level_); }
+
+ private:
+  int kind_;
+  int level_;
+};
+
+template <>
+void WriteStream<TimestampC>(std::ostream& stream, const TimestampC& node);
+
+class TimestampC final : public CtOp {
+ public:
+  explicit TimestampC(const LevelInfo& level_info, int kind, int idx)
+      : CtOp(level_info), kind_(kind), idx_(idx) {}
+  std::unique_ptr<CtOp> CloneUniq() const final {
+    return std::make_unique<TimestampC>(GetLevelInfo(), kind_, idx_);
+  }
+  void WriteStreamHelper(std::ostream& stream) const final {
+    WriteStream<TimestampC>(stream, *this);
+  }
+
+  int Kind() const { return kind_; }
+  int Idx() const { return idx_; }
+
+  const std::string& TypeName() const final { return StaticTypeName(); }
+  static const std::string& StaticTypeName() {
+    static const std::string type_name_ = "TimestampC";
+    return type_name_;
+  }
+
+ private:
+  void WriteToStream(std::ostream& stream) const;
+
+  int kind_;
+  int idx_;
+
+  static const std::string type_name_;
+  static CtOpDerivedRegistrar<TimestampC> reg_;
+};
+
+inline CtOpDerivedRegistrar<TimestampC> TimestampC::reg_{
+    TimestampC::StaticTypeName()};
+
+template <>
+inline void WriteStream<TimestampC>(std::ostream& stream,
+                                    const TimestampC& node) {
+  WriteStream<std::string>(stream, TimestampC::StaticTypeName());
+  stream << " ";
+  WriteStream<LevelInfo>(stream, node.GetLevelInfo());
+  stream << " ";
+  WriteStream<int>(stream, node.Kind());
+  stream << " ";
+  WriteStream<int>(stream, node.Idx());
+}
+
+template <>
+inline TimestampC ReadStreamWithoutTypeNamePrefix<TimestampC>(
+    std::istream& stream) {
+  auto level_info = ReadStream<LevelInfo>(stream);
+  auto kind = ReadStream<int>(stream);
+  auto idx = ReadStream<int>(stream);
+  return TimestampC(level_info, kind, idx);
+}
+
+}  // namespace fhelipe
+
+#endif  // FHELIPE_TIMESTAMP_C_H_
